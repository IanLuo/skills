{
  "version": 1,
  "steps": [
    {
      "id": "step-1-prd",
      "name": "Requirements Analysis",
      "persona": "analyst",
      "workflow": "analyst-workflow",
      "inputs": [
        { "file": "docs/architecture.md" },
        { "file": "docs/detailed-components.md" },
        { "file": "docs/ui-ux/design-system.md" },
        { "file": "docs/tasks/plan.md" },
        { "file": "docs/qa/" }
      ],
      "outputs": [
        { "file": "docs/prd/v{version}.md", "schema": "schemas/prd.schema.json" }
      ],
      "gates": [
        {
          "type": "user_approval",
          "prompt": "Review docs/prd/v{version}.md. Approve to continue or reject for rework."
        }
      ],
      "on_pass": "step-2a-architecture",
      "on_fail": { "target": "step-1-prd", "reason": "User rejected PRD. Analyst reworks with feedback." }
    },
    {
      "id": "step-2a-architecture",
      "name": "Architecture Update",
      "persona": "architect",
      "workflow": "architect-workflow",
      "inputs": [
        { "file": "docs/prd/v{version}.md" },
        { "file": "docs/architecture.md" },
        { "file": "docs/detailed-components.md" }
      ],
      "outputs": [
        { "file": "docs/architecture.md" },
        { "file": "docs/detailed-components.md" }
      ],
      "gates": [
        { "type": "boundary_check" }
      ],
      "on_pass": "step-2b-designer",
      "on_fail": { "target": "step-2a-architecture", "reason": "Architecture boundary violation. Architect fixes." }
    },
    {
      "id": "step-2b-designer",
      "name": "UI/UX Update",
      "persona": "designer",
      "workflow": "designer-workflow",
      "inputs": [
        { "file": "docs/prd/v{version}.md" },
        { "file": "docs/architecture.md" },
        { "file": "docs/ui-ux/" }
      ],
      "outputs": [
        { "file": "docs/ui-ux/" }
      ],
      "gates": [
        { "type": "consistency_check" }
      ],
      "on_pass": "step-2-review",
      "on_fail": { "target": "step-2b-designer", "reason": "UI/UX inconsistency with architecture. Designer fixes." }
    },
    {
      "id": "step-2-review",
      "name": "Design Review Gate",
      "persona": "project-steward",
      "workflow": null,
      "inputs": [],
      "outputs": [],
      "gates": [
        { "type": "schema_validation" },
        { "type": "boundary_check" },
        { "type": "consistency_check" }
      ],
      "on_pass": "step-3-planner",
      "on_fail": { "target": "step-2a-architecture", "reason": "Design review failed. Architecture or UI/UX issue. Steward specifies root." }
    },
    {
      "id": "step-3-planner",
      "name": "Task Planning",
      "persona": "planner",
      "workflow": "planner-workflow",
      "inputs": [
        { "file": "docs/prd/v{version}.md" },
        { "file": "docs/architecture.md" },
        { "file": "docs/detailed-components.md" },
        { "file": "docs/ui-ux/" }
      ],
      "outputs": [
        { "file": "docs/tasks/plan.md" }
      ],
      "gates": [
        { "type": "self_consistency" }
      ],
      "on_pass": "step-4-cross-review",
      "on_fail": { "target": "step-3-planner", "reason": "Self-consistency check failed. Planner fixes." }
    },
    {
      "id": "step-4-cross-review",
      "name": "Cross-Review Gate",
      "persona": "project-steward",
      "workflow": null,
      "inputs": [],
      "outputs": [],
      "gates": [
        {
          "type": "persona_cascade",
          "personas": ["gatekeeper", "reviewer", "tester", "strategist"]
        },
        {
          "type": "doc_coherence",
          "files": ["docs/prd/v{version}.md", "docs/architecture.md", "docs/ui-ux/", "docs/tasks/plan.md"]
        }
      ],
      "on_pass": "step-5-qa-design",
      "on_fail": {
        "target": null,
        "reason": "Dynamic: PRD gap→step-1-prd, architecture gap→step-2a-architecture, UI/UX gap→step-2b-designer, plan gap→step-3-planner. Steward writes target into steward-log."
      }
    },
    {
      "id": "step-5-qa-design",
      "name": "QA Test Design",
      "persona": "qa-architect",
      "workflow": "qa-design-workflow",
      "inputs": [
        { "file": "docs/prd/v{version}.md" },
        { "file": "docs/architecture.md" },
        { "file": "docs/detailed-components.md" },
        { "file": "docs/ui-ux/" },
        { "file": "docs/tasks/plan.md" }
      ],
      "outputs": [
        { "file": "docs/qa/test-plan-v{version}.md", "schema": "schemas/test-plan.schema.json" },
        { "file": "tests/functional/", "optional": true }
      ],
      "gates": [
        { "type": "traceability" }
      ],
      "on_pass": "step-6-dev",
      "on_fail": { "target": "step-5-qa-design", "reason": "Traceability gate failed. QA Architect adds missing trace links." }
    },
    {
      "id": "step-6-dev",
      "name": "Development",
      "persona": null,
      "workflow": "dev-workflow",
      "inputs": [
        { "file": "docs/tasks/plan.md" }
      ],
      "outputs": [],
      "gates": [],
      "on_pass": "step-7-qa-exec",
      "on_fail": { "target": "step-6-dev", "reason": "dev-workflow review gate failed. Loops internally via TDD." }
    },
    {
      "id": "step-7-qa-exec",
      "name": "QA Execution",
      "persona": null,
      "workflow": "qa-exec-workflow",
      "inputs": [
        { "file": "docs/qa/test-plan-v{version}.md" },
        { "file": "docs/prd/v{version}.md" }
      ],
      "outputs": [
        { "file": "docs/qa/report-v{version}.md", "schema": "schemas/qa-report.schema.json" }
      ],
      "gates": [
        { "type": "qa_pass", "threshold": "zero critical/high bugs" }
      ],
      "on_pass": null,
      "on_fail": {
        "target": null,
        "reason": "Dynamic: bug→step-6-dev, design-gap→step-2a-architecture, prd-gap→step-1-prd. QA Executor writes rebound_target into report."
      }
    }
  ]
}
