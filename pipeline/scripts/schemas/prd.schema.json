{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PRD Schema",
  "description": "Schema for version PRD documents (docs/prd/v{N}.md)",
  "type": "object",
  "required": ["title", "version", "source", "current_state", "changes_required", "acceptance_criteria"],
  "properties": {
    "title": {
      "type": "string",
      "description": "Short human-readable title for this PRD"
    },
    "version": {
      "type": "integer",
      "description": "Version number matching {N} in filename"
    },
    "source": {
      "type": "string",
      "description": "Where the requirement came from — user request, bug report, design gap"
    },
    "current_state": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Bullet list of what currently exists (files, components, APIs)"
    },
    "changes_required": {
      "type": "object",
      "properties": {
        "architecture": { "type": "array", "items": { "type": "string" } },
        "ui_ux": { "type": "array", "items": { "type": "string" } },
        "plan": { "type": "array", "items": { "type": "string" } }
      },
      "description": "Changes grouped by affected doc"
    },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Checklist of verifiable criteria for this version"
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Optional — PRD versions or external dependencies"
    }
  }
}
