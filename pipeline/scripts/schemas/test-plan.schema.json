{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Test Plan Schema",
  "description": "Schema for QA test plan documents (docs/qa/test-plan-v{N}.md)",
  "type": "object",
  "required": ["version", "tests", "traceability"],
  "properties": {
    "version": {
      "type": "integer",
      "description": "Version number matching {N} in filename"
    },
    "tests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "precondition", "steps", "expected"],
        "properties": {
          "id": { "type": "string", "description": "Unique test case ID (e.g., TC-001)" },
          "description": { "type": "string" },
          "precondition": { "type": "string" },
          "steps": { "type": "array", "items": { "type": "string" } },
          "expected": { "type": "string" },
          "plan_task": { "type": "string", "description": "Task ID this test maps to (e.g., 9.1)" },
          "prd_criterion": { "type": "string", "description": "Which PRD acceptance criterion this validates" }
        }
      }
    },
    "traceability": {
      "type": "object",
      "description": "Must map every test to a plan task and PRD criterion",
      "patternProperties": {
        "^TC-": {
          "type": "object",
          "required": ["plan_task", "prd_criterion"],
          "properties": {
            "plan_task": { "type": "string" },
            "prd_criterion": { "type": "string" }
          }
        }
      }
    }
  }
}
