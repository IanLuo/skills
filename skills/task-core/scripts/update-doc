#!/usr/bin/env bash
set -euo pipefail

DOC=""
NOTE=""
while [ $# -gt 0 ]; do
  case "$1" in
    --doc) DOC="${2:-}"; shift 2 ;;
    --note) NOTE="${2:-}"; shift 2 ;;
    *) printf 'update-doc: unknown argument: %s\n' "$1" >&2; exit 2 ;;
  esac
done

[ -n "$DOC" ] || { printf 'update-doc: --doc is required\n' >&2; exit 2; }
[ -n "$NOTE" ] || { printf 'update-doc: --note is required\n' >&2; exit 2; }

if [ ! -f "$DOC" ]; then
  mkdir -p "$(dirname "$DOC")"
  printf '# Task Notes\n\n' >"$DOC"
fi

printf '\n- %s\n' "$NOTE" >>"$DOC"
